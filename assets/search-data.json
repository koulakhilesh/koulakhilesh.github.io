{%- assign sep = "," -%}
{% endfor -%}
{% for m in site.making -%}
{{ sep }}{"title":{{ m.title | jsonify }},"url":{{ m.url | relative_url | jsonify }},"type":"Making","summary":{{ m.summary | default: m.excerpt | default: "" | strip_html | strip_newlines | truncate: 140 | jsonify }}}
{%- assign sep = "," -%}
{% endfor -%}
